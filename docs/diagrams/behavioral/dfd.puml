@startuml Data Flow Diagram
!theme plain
skinparam rectangle {
    BackgroundColor White
    BorderColor Black
}

title DFD Nivel 0 - Sistema UniversityScheduler

actor "Autenticado Estudiante" as student

rectangle "UniversityScheduler System" as us {
    usecase "Gestión Académica Core" as core
    usecase "Gestión de Tareas" as tasks
    usecase "Evaluaciones y Notas" as grades
    usecase "Tutorías y Profesores" as directory
}

database "PostgreSQL DB" as db

student --> core : Introduce Semestres y Materias
core --> student : Visualiza Horario de Clases

student --> tasks : Gestiona entregables
tasks --> student : Muestra Tablero Kanban

student --> grades : Registra calificaciones
grades --> student : Devuelve promedio ponderado

student --> directory : Agenda citas
directory --> student : Confirma reserva

core --> db : Almacena estructura base
tasks --> db : Almacena estados
grades --> db : Computa progreso
directory --> db : Cruza disponibilidad horaria

@enduml
